PORT=3000
NODE_ENV=development

MONGO_URI=mongodb://localhost:27017/sns03
REDIS_URL=redis://127.0.0.1:6379

JWT_ACCESS_SECRET=change_this_access_secret_min_32chars
JWT_REFRESH_SECRET=change_this_refresh_secret_min_32chars
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=14d

UPLOAD_DIR=./uploads
PUBLIC_UPLOAD_URL=/uploads
MAX_FILE_SIZE=5242880
MAX_FILES=3

CORS_ORIGIN=http://localhost:3000
BCRYPT_COST=10

RATE_LIMIT_GLOBAL=100
RATE_LIMIT_LOGIN=10

# 다중 WAS 환경 (docker-compose 에서는 환경 변수로 주입)
INSTANCE_ID=
LOG_TO_STDOUT_ONLY=false
SOCKET_IO_PATH=/socket.io
TRUST_PROXY=false
